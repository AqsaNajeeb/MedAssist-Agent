    {
      "cell_type": "markdown",
      "source": [
        "# Initialize Groq Client and Response Generation Function"
      ],
      "metadata": {
        "id": "_OPCuoxQ0yZG"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from groq import Groq\n",
        "\n",
        "client = Groq(api_key=GROQ_API_KEY)\n",
        "\n",
        "def generate(prompt, system=\"You are a helpful medical assistant.\"):\n",
        "    response = client.chat.completions.create(\n",
        "        model=\"llama-3.3-70b-versatile\",\n",
        "        messages=[\n",
        "            {\"role\": \"system\", \"content\": system},\n",
        "            {\"role\": \"user\",   \"content\": prompt}\n",
        "        ],\n",
        "        max_tokens=1024\n",
        "    )\n",
        "    return response.choices[0].message.content\n",
        "\n",
        "# Test it\n",
        "print(generate(\"Say hello in one sentence\"))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "SNI02JAI0zVy",
        "outputId": "faf1c6f4-8056-441b-e12d-3a4e5b5dfe5b"
      },
      "execution_count": 3,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Hello, I'm a friendly medical assistant here to help answer your health-related questions and provide support in any way I can.\n"
          ]
        }
      ]

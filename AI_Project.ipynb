        "# CSV Logging System for MedAssist Interaction History"
      ],
      "metadata": {
        "id": "kkVPphj32vdd"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import csv\n",
        "import os\n",
        "from datetime import datetime\n",
        "\n",
        "LOG_FILE = \"medassist_log.csv\"\n",
        "\n",
        "def init_log():\n",
        "    if not os.path.exists(LOG_FILE):\n",
        "        with open(LOG_FILE, \"w\", newline=\"\", encoding=\"utf-8\") as f:\n",
        "            writer = csv.writer(f)\n",
        "            writer.writerow([\"timestamp\", \"user_input\", \"language\", \"task_type\", \"result\"])\n",
        "\n",
        "def save_log(user_input, language, task_type, result):\n",
        "    with open(LOG_FILE, \"a\", newline=\"\", encoding=\"utf-8\") as f:\n",
        "        writer = csv.writer(f)\n",
        "        writer.writerow([\n",
        "            datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n",
        "            user_input,\n",
        "            language,\n",
        "            task_type,\n",
        "            result[:500]  # save first 500 chars\n",
        "        ])\n",
        "\n",
        "def view_log():\n",
        "    if not os.path.exists(LOG_FILE):\n",
        "        print(\"No log yet.\")\n",
        "        return\n",
        "    with open(LOG_FILE, \"r\", encoding=\"utf-8\") as f:\n",
        "        reader = csv.reader(f)\n",
        "        for row in reader:\n",
        "            print(row)\n",
        "\n",
        "init_log()\n",
        "print(\"✅ CSV logging ready →\", LOG_FILE)"
      ],
      "metadata": {
        "id": "xJRo4hJu2wZK",
        "outputId": "11dc2697-b251-4bea-ce2c-c8bab79f4a2c",
        "colab": {
          "base_uri": "https://localhost:8080/"
        }
      },

    {
      "cell_type": "markdown",
      "source": [
        "# Language Detection for English, Urdu, and Roman Urdu Input"
      ],
      "metadata": {
        "id": "4GlcUKwD02mn"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def detect_language(text):\n",
        "    # Check for Urdu script characters\n",
        "    for char in text:\n",
        "        if '\\u0600' <= char <= '\\u06FF':\n",
        "            return \"URDU\"\n",
        "\n",
        "    # Check for Roman Urdu common words\n",
        "    roman_urdu_words = [\n",
        "        \"mjy\", \"mujhe\", \"karo\", \"batao\", \"hai\", \"hain\", \"ky\", \"ka\",\n",
        "        \"ki\", \"ko\", \"mn\", \"mein\", \"ap\", \"aap\", \"kya\", \"nahi\", \"aur\",\n",
        "        \"krny\", \"karna\", \"wala\", \"hua\", \"thi\", \"tha\", \"hoga\"\n",
        "    ]\n",
        "    text_lower = text.lower()\n",
        "    for word in roman_urdu_words:\n",
        "        if word in text_lower.split():\n",
        "            return \"URDU\"\n",
        "\n",
        "    return \"ENGLISH\""
      ],
      "metadata": {
        "id": "5wl7tWlU04oy"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Task Classification for Medical Queries"
      ],
      "metadata": {
        "id": "YaVcBCWg07YE"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def classify_task(text):\n",
        "    text_lower = text.lower()\n",
        "\n",
        "    # Lab test keywords\n",
        "    lab_keywords = [\n",
        "        \"hba1c\", \"hemoglobin\", \"wbc\", \"rbc\", \"glucose\", \"cholesterol\",\n",
        "        \"test\", \"result\", \"level\", \"mg\", \"g/dl\", \"mmol\", \"%\",\n",
        "        \"blood\", \"urine\", \"report\", \"value\", \"normal\", \"abnormal\",\n",
        "        \"khoon\", \"sugar\", \"test\", \"nتیجہ\"\n",
        "    ]\n",
        "\n",
        "    # Terminology keywords\n",
        "    term_keywords = [\n",
        "        \"what is\", \"what does\", \"meaning\", \"define\", \"explain\",\n",
        "        \"diagnosed with\", \"prescribed\", \"syndrome\", \"disorder\",\n",
        "        \"kya hai\", \"matlab\", \"batao\", \"samjhao\", \"کیا ہے\", \"مطلب\"\n",
        "    ]\n",
        "\n",
        "    # Literature/research keywords\n",
        "    lit_keywords = [\n",
        "        \"research\", \"study\", \"studies\", \"evidence\", \"pubmed\",\n",
        "        \"treatment\", \"therapy\", \"effective\", \"cure\", \"latest\",\n",
        "        \"tareeqa\", \"ilaj\", \"طریقہ\", \"علاج\", \"stress\", \"anxiety\"\n",
        "    ]\n",
        "\n",
        "    for word in lab_keywords:\n",
        "        if word in text_lower:\n",
        "            return \"LAB_TEST\"\n",
        "\n",
        "    for word in term_keywords:\n",
        "        if word in text_lower:\n",
        "            return \"TERMINOLOGY\"\n",
        "\n",
        "    for word in lit_keywords:\n",
        "        if word in text_lower:\n",
        "            return \"LITERATURE\"\n",
        "\n",
        "    return \"TERMINOLOGY\"  # default fallback"
      ],
      "metadata": {
        "id": "z16KK6Mk08d6"
      },
      "execution_count": 6,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Medical Query Handlers: Lab Tests, Terminology, and Literature Responses"
      ],
      "metadata": {
        "id": "9-3hQYlC0_S4"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def lab_test_interpreter(user_input, language):\n",
        "    if language == \"URDU\":\n",
        "        system = \"آپ ایک طبی معاون ہیں۔ خون کے ٹیسٹ کی قدریں سادہ اردو میں سمجھائیں۔\"\n",
        "        prompt = f\"یہ میرے ٹیسٹ کے نتائج ہیں:\\n{user_input}\\nہر قدر کو سمجھائیں کہ نارمل ہے یا نہیں اور کیا کرنا چاہیے۔\"\n",
        "    else:\n",
        "        system = \"You are a medical assistant. Explain lab results in simple, clear English for patients.\"\n",
        "        prompt = f\"\"\"Analyze these lab test values:\n",
        "{user_input}\n",
        "\n",
        "For each value:\n",
        "1. State if NORMAL ✅ or ABNORMAL ⚠️\n",
        "2. Give the normal range\n",
        "3. Explain what it means simply\n",
        "4. Give one practical suggestion\n",
        "\n",
        "End with a short summary.\"\"\"\n",
        "\n",
        "    return generate(prompt, system)\n",
        "\n",
        "\n",
        "def terminology_explainer(user_input, language):\n",
        "    if language == \"URDU\":\n",
        "        system = \"آپ ایک طبی معاون ہیں۔ مشکل طبی الفاظ سادہ اردو میں سمجھائیں۔\"\n",
        "        prompt = f\"یہ طبی الفاظ یا جملہ سمجھائیں:\\n{user_input}\"\n",
        "    else:\n",
        "        system = \"You are a medical assistant. Explain medical terms in very simple English.\"\n",
        "        prompt = f\"\"\"Explain the medical terms in this text:\n",
        "{user_input}\n",
        "\n",
        "For each medical term:\n",
        "1. Give a simple everyday meaning\n",
        "2. One sentence explanation\n",
        "\n",
        "End with a plain English summary of the whole thing.\"\"\"\n",
        "\n",
        "    return generate(prompt, system)\n",
        "\n",
        "\n",
        "def literature_analyzer(user_input, language):\n",
        "    if language == \"URDU\":\n",
        "        system = \"آپ ایک طبی معاون ہیں۔ طبی سوالوں کے جواب سادہ اردو میں دیں۔\"\n",
        "        prompt = f\"اس طبی موضوع پر معلومات دیں:\\n{user_input}\\nآسان الفاظ میں بتائیں۔\"\n",
        "    else:\n",
        "        system = \"You are a medical research assistant. Answer based on established medical knowledge.\"\n",
        "        prompt = f\"\"\"Answer this medical question based on research:\n",
        "{user_input}\n",
        "\n",
        "Structure your answer as:\n",
        "- Key Findings (3-4 bullet points)\n",
        "- What This Means For You (simple explanation)\n",
        "- Key Takeaways (numbered list)\"\"\"\n",
        "\n",
        "    return generate(prompt, system)"
      ],
      "metadata": {
        "id": "AakRPG-i1AeJ"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Medical Image Analysis using Groq Vision Model"
      ],
      "metadata": {
        "id": "pzY24W0z1DXV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import base64\n",
        "from pathlib import Path\n",
        "\n",
        "def encode_image(image_path):\n",
        "    \"\"\"Convert image to base64\"\"\"\n",
        "    with open(image_path, \"rb\") as f:\n",
        "        return base64.b64encode(f.read()).decode(\"utf-8\")\n",
        "\n",
        "def analyze_image(image_path, language, user_question=\"\"):\n",
        "    \"\"\"Analyze any medical image or lab report photo\"\"\"\n",
        "\n",
        "    # Check file exists\n",
        "    if not Path(image_path).exists():\n",
        "        return \"❌ Image file not found. Please check the path.\"\n",
        "\n",
        "    # Get file extension\n",
        "    ext = Path(image_path).suffix.lower()\n",
        "    mime_types = {\n",
        "        \".jpg\": \"image/jpeg\",\n",
        "        \".jpeg\": \"image/jpeg\",\n",
        "        \".png\": \"image/png\",\n",
        "        \".webp\": \"image/webp\"\n",
        "    }\n",
        "    mime_type = mime_types.get(ext, \"image/jpeg\")\n",
        "\n",
        "    # Encode image\n",
        "    image_data = encode_image(image_path)\n",
        "\n",
        "    # Build prompt based on language\n",
        "    if language == \"URDU\":\n",
        "        if user_question:\n",
        "            prompt = f\"یہ میڈیکل تصویر دیکھیں اور اس سوال کا جواب اردو میں دیں: {user_question}\"\n",
        "        else:\n",
        "            prompt = \"\"\"یہ میڈیکل تصویر یا لیب رپورٹ دیکھیں اور اردو میں بتائیں:\n",
        "1. یہ کس قسم کی تصویر یا رپورٹ ہے؟\n",
        "2. اہم نتائج کیا ہیں؟\n",
        "3. کوئی غیر معمولی چیز ہے تو بتائیں\n",
        "4. مریض کو کیا کرنا چاہیے؟\"\"\"\n",
        "    else:\n",
        "        if user_question:\n",
        "            prompt = f\"Look at this medical image and answer: {user_question}\"\n",
        "        else:\n",
        "            prompt = \"\"\"Analyze this medical image or lab report and explain:\n",
        "1. What type of image/report is this?\n",
        "2. What are the key findings?\n",
        "3. Are there any abnormal values or concerning findings? Flag them with ⚠️\n",
        "4. What should the patient do next?\n",
        "\n",
        "Keep the explanation simple and patient-friendly.\"\"\"\n",
        "\n",
        "    # Call Groq vision model\n",
        "    try:\n",
        "        response = client.chat.completions.create(\n",
        "            model=\"meta-llama/llama-4-scout-17b-16e-instruct\",  # Groq's vision model\n",
        "            messages=[\n",
        "                {\n",
        "                    \"role\": \"user\",\n",
        "                    \"content\": [\n",
        "                        {\n",
        "                            \"type\": \"image_url\",\n",
        "                            \"image_url\": {\n",
        "                                \"url\": f\"data:{mime_type};base64,{image_data}\"\n",
        "                            }\n",
        "                        },\n",
        "                        {\n",
        "                            \"type\": \"text\",\n",
        "                            \"text\": prompt\n",
        "                        }\n",
        "                    ]\n",
        "                }\n",
        "            ],\n",
        "            max_tokens=1024\n",
        "        )\n",
        "        return response.choices[0].message.content\n",
        "\n",
        "    except Exception as e:\n",
        "        return f\"❌ Image analysis failed: {str(e)}\""
      ],
      "metadata": {
        "id": "aGtPOaBu1E9D"
      },
      "execution_count": 8,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# MedAssist Agent: Main Orchestration Pipeline"
      ],
      "metadata": {
        "id": "94AciVWY1JZ1"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def medassist_agent(user_input):\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"🤖 MedAssist Agent Processing...\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    language = detect_language(user_input)\n",
        "    print(f\"🌐 Language detected: {language}\")\n",
        "\n",
        "    task = classify_task(user_input)\n",
        "    print(f\"📋 Task type: {task}\")\n",
        "\n",
        "    if task == \"LAB_TEST\":\n",
        "        print(\"🔬 Running Lab Test Interpreter...\")\n",
        "        result = lab_test_interpreter(user_input, language)\n",
        "    elif task == \"TERMINOLOGY\":\n",
        "        print(\"📖 Running Terminology Explainer...\")\n",
        "        result = terminology_explainer(user_input, language)\n",
        "    elif task == \"LITERATURE\":\n",
        "        print(\"📚 Running Literature Analyzer...\")\n",
        "        result = literature_analyzer(user_input, language)\n",
        "\n",
        "    print(\"\\n📄 RESULT:\\n\")\n",
        "    print(result)\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    # Save to CSV\n",
        "    save_log(user_input, language, task, result)"
      ],
      "metadata": {
        "id": "qAt8jxKT1KrU"
      },
      "execution_count": 9,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# MedAssist Chat Loop and Logging System (CLI + Image Upload Interface)"
      ],
      "metadata": {
        "id": "Gq-tdC2Q1PXV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import threading\n",
        "import csv\n",
        "from datetime import datetime\n",
        "stop_flag = threading.Event()\n",
        "\n",
        "def save_log(user_input, language, task, result, filename=\"medassist_log.csv\"):\n",
        "    \"\"\"Logs the interaction to a CSV file.\"\"\"\n",
        "    timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n",
        "    log_entry = [timestamp, user_input, language, task, result]\n",
        "\n",
        "    try:\n",
        "        with open(filename, 'a', newline='', encoding='utf-8') as f:\n",
        "            writer = csv.writer(f)\n",
        "            # Write header if file is empty\n",
        "            if f.tell() == 0:\n",
        "                writer.writerow([\"Timestamp\", \"User Input\", \"Language\", \"Task Type\", \"Response\"])\n",
        "            writer.writerow(log_entry)\n",
        "        # print(f\"Log saved to {filename}\") # Optional: uncomment for verbose logging confirmation\n",
        "    except Exception as e:\n",
        "        print(f\"Error saving log: {e}\")\n",
        "\n",
        "def chat_loop():\n",
        "    print(\"=\"*60)\n",
        "    print(\"   Welcome to MedAssist Agent 🏥\")\n",
        "    print(\"   Type 'quit' or 'exit' to stop\")\n",
        "    print(\"   Type 'image' to upload a medical image\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    while not stop_flag.is_set():\n",
        "        try:\n",
        "            user_input = input(\"\\n👤 You: \").strip()\n",
        "        except (EOFError, KeyboardInterrupt):\n",
        "            break\n",
        "\n",
        "        if not user_input:\n",
        "            continue\n",
        "\n",
        "        if user_input.lower() in [\"quit\", \"exit\", \"bye\", \"stop\"]:\n",
        "            print(\"\\n👋 Goodbye! Stay healthy!\")\n",
        "            stop_flag.set()\n",
        "            break\n",
        "\n",
        "        # ── IMAGE MODE ──────────────────────────────────────\n",
        "        elif user_input.lower() == \"image\":\n",
        "            print(\"\\n📁 Enter the image path (or press Enter to upload in Colab):\")\n",
        "\n",
        "            # Colab file upload\n",
        "            try:\n",
        "                from google.colab import files\n",
        "                print(\"   Opening file picker...\")\n",
        "                uploaded = files.upload()\n",
        "\n",
        "                if uploaded:\n",
        "                    image_path = list(uploaded.keys())[0]\n",
        "                    print(f\"   ✅ Uploaded: {image_path}\")\n",
        "\n",
        "                    # Ask follow-up question\n",
        "                    question = input(\"   ❓ Any specific question about this image? (Press Enter to skip): \").strip()\n",
        "\n",
        "                    # Detect language from question if provided\n",
        "                    language = detect_language(question) if question else \"ENGLISH\"\n",
        "\n",
        "                    print(\"\\n\" + \"=\"*60)\n",
        "                    print(\"🤖 MedAssist Agent Processing...\")\n",
        "                    print(\"=\"*60)\n",
        "                    print(f\"🌐 Language detected: {language}\")\n",
        "                    print(\"🖼️  Running Image Analyzer...\")\n",
        "\n",
        "                    result = analyze_image(image_path, language, question)\n",
        "\n",
        "                    print(\"\\n📄 RESULT:\\n\")\n",
        "                    print(result)\n",
        "                    print(\"=\"*60)\n",
        "\n",
        "                    # Save to log\n",
        "                    save_log(f\"[IMAGE] {image_path} | Q: {question}\", language, \"IMAGE\", result)\n",
        "\n",
        "                else:\n",
        "                    print(\"   ❌ No file uploaded.\")\n",
        "\n",
        "            except Exception as e:\n",
        "                print(f\"   ❌ Upload failed: {str(e)}\")\n",
        "                print(\"   💡 Try providing the full path instead, e.g.: /content/report.jpg\")\n",
        "\n",
        "        # ── TEXT MODE ────────────────────────────────────────\n",
        "        else:\n",
        "            medassist_agent(user_input)\n",
        "\n",
        "# Run it\n",
        "stop_flag.clear()\n",
        "chat_loop()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "qjAY10Q_1QZV",
        "outputId": "4b46f527-8387-431e-c303-bfd144264136"
      },
      "execution_count": 10,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "============================================================\n",
            "   Welcome to MedAssist Agent 🏥\n",
            "   Type 'quit' or 'exit' to stop\n",
            "   Type 'image' to upload a medical image\n",
            "============================================================\n",
            "\n",
            "👤 You: mera bp 90/60 ha. mujy kia hua ha?\n",
            "\n",
            "============================================================\n",
            "🤖 MedAssist Agent Processing...\n",
            "============================================================\n",
            "🌐 Language detected: URDU\n",
            "📋 Task type: TERMINOLOGY\n",
            "📖 Running Terminology Explainer...\n",
            "\n",
            "📄 RESULT:\n",
            "\n",
            "آپ کا بلڈ پریشر (BP) 90/60 ہے۔ اس کا مطلب ہے کہ آپ کا sysٹولک (اوپر والا) پریشر 90 mmHg ہے، جو عام طور پر 120-140 کے درمیان ہوتا ہے، اور آپ کا دیاسٹولک (نیچے والا) پریشر 60 mmHg ہے، جو عام طور پر 80-90 کے درمیان ہوتا ہے۔\n",
            "\n",
            "90/60 کا بلڈ پریشر نسبتاً کم ہے اور اسے ہائیپوٹینشن (low blood pressure) کہتے ہیں۔ ہائیپوٹینشن کی مختلف وجوہات ہو سکتی ہیں، جیسے کہ:\n",
            "\n",
            "* کم پانی کی مقدار (hydratation)\n",
            "* خون کی کمی (anemia)\n",
            "* کارڈیو واسکولر بیماری (cardiovascular disease)\n",
            "* اعصابی نظام کے مسائل (neurological disorders)\n",

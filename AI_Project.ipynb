      "source": [
        "# PubMed Research Integration for Literature-Based Medical Answers"
      ],
      "metadata": {
        "id": "9ykrbZRG2kal"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import requests\n",
        "import xml.etree.ElementTree as ET\n",
        "\n",
        "def search_pubmed(query, max_results=3):\n",
        "    \"\"\"Search PubMed and return paper titles + abstracts\"\"\"\n",
        "    try:\n",
        "        # Step 1: Search for IDs\n",
        "        search_url = \"https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi\"\n",
        "        search_params = {\n",
        "            \"db\": \"pubmed\",\n",
        "            \"term\": query,\n",
        "            \"retmax\": max_results,\n",
        "            \"retmode\": \"json\"\n",
        "        }\n",
        "        search_resp = requests.get(search_url, params=search_params, timeout=10)\n",
        "        ids = search_resp.json()[\"esearchresult\"][\"idlist\"]\n",
        "\n",
        "        if not ids:\n",
        "            return \"No PubMed articles found for this query.\"\n",
        "\n",
        "        # Step 2: Fetch details\n",
        "        fetch_url = \"https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi\"\n",
        "        fetch_params = {\n",
        "            \"db\": \"pubmed\",\n",
        "            \"id\": \",\".join(ids),\n",
        "            \"retmode\": \"xml\"\n",
        "        }\n",
        "        fetch_resp = requests.get(fetch_url, params=fetch_params, timeout=10)\n",
        "        root = ET.fromstring(fetch_resp.content)\n",
        "\n",
        "        papers = []\n",
        "        for article in root.findall(\".//PubmedArticle\"):\n",
        "            title = article.findtext(\".//ArticleTitle\", \"No title\")\n",
        "            abstract = article.findtext(\".//AbstractText\", \"No abstract available\")\n",
        "            year = article.findtext(\".//PubDate/Year\", \"Unknown year\")\n",
        "            papers.append(f\"📄 [{year}] {title}\\n   {abstract[:300]}...\")\n",
        "\n",
        "        return \"\\n\\n\".join(papers)\n",
        "\n",
        "    except Exception as e:\n",
        "        return f\"PubMed search failed: {str(e)}\"\n",
        "\n",
        "\n",
        "# Update literature_analyzer to use REAL PubMed\n",
        "def literature_analyzer(user_input, language):\n",
        "    print(\"   🔍 Searching PubMed for real research...\")\n",
        "    pubmed_results = search_pubmed(user_input)\n",
        "\n",
        "    if language == \"URDU\":\n",
        "        system = \"آپ ایک طبی معاون ہیں۔ طبی سوالوں کے جواب سادہ اردو میں دیں۔\"\n",
        "        prompt = f\"\"\"اس طبی موضوع پر PubMed سے یہ تحقیق ملی ہے:\n",
        "\n",
        "{pubmed_results}\n",
        "\n",
        "صارف کا سوال: {user_input}\n",
        "\n",
        "ان نتائج کو آسان اردو میں سمجھائیں۔\"\"\"\n",
        "    else:\n",
        "        system = \"You are a medical research assistant. Summarize PubMed research clearly.\"\n",
        "        prompt = f\"\"\"The user asked: {user_input}\n",
        "\n",
        "Real PubMed research found:\n",
        "{pubmed_results}\n",
        "\n",
        "Structure your answer as:\n",
        "- Key Findings (3-4 bullet points from the papers above)\n",
        "- What This Means For You (simple explanation)\n",
        "- Key Takeaways (numbered list)\n",
        "- Source: Summarized from PubMed research\"\"\"\n",
        "\n",
        "    return generate(prompt, system)"
      ],
      "metadata": {
        "id": "QNa-c8rW2lkB"
      },
      "execution_count": 12,
      "outputs": []
    },
